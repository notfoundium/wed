---
import "../styles/global.css";

/** Замените на свои данные */
const couple = {
	names: "Анна и Тимур",
	tagline: "приглашаем вас разделить с нами день нашей свадьбы",
};

const wedding = {
	iso: "2026-08-15T16:00:00",
	dateLabel: "12 сентября 2026",
	timeLabel: "15:00",
	timezone: "Москва",
};

const venue = {
	ceremonyTitle: "Церемония",
	ceremonyPlace: "Отель «Эдж Селигерская»",
	ceremonyAddress: "г. Москва, Коровинское шоссе, 10",
	mapsUrl: "https://yandex.ru/maps/org/edzh_seligerskaya/1867560286/?ll=37.535646%2C55.870839&z=16",
};
 
const program = [
	{ time: "15:00", title: "Сбор гостей", detail: "фуршет на веранде" },
	{ time: "16:00", title: "Церемония", detail: "веранда зала" },
	{ time: "17:00", title: "Банкет", detail: "банкетный зал" },
	{ time: "20:00", title: "Торт и танцы", detail: "" },
];

const dressCode = "Подумать надо";

const rsvp = {
	deadline: "до 1 июля 2026",
	contacts: [
		{
			label: "Анна",
			email: "dududu",
			phone: "+7 909 649-68-16",
		},
		{
			label: "Тимур",
			email: "t.r.yakubov@gmail.com",
			phone: "+7 995 506-54-37",
		},
	],
} as const;

const dialHref = (phone: string) => `tel:${phone.replace(/[\s().-]/g, "")}`;

const weddingTs = new Date(wedding.iso).getTime();
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={`Свадебное приглашение — ${couple.names}, ${wedding.dateLabel}`} />
		<title>{couple.names} — свадьба</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Source+Sans+3:wght@300;400;500;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<a class="sr-only" href="#main">Перейти к содержимому</a>

		<header class="hero" id="top">
			<p class="hero__eyebrow">Свадьба</p>
			<h1 class="hero__title">{couple.names}</h1>
			<p class="hero__tagline">{couple.tagline}</p>
			<p class="hero__date">{wedding.dateLabel} · {wedding.timeLabel} ({wedding.timezone})</p>
			<div class="hero__countdown" id="countdown" aria-live="polite" data-ts={weddingTs}>
				<span class="hero__countdown-label">До торжества</span>
				<span class="hero__countdown-value" id="countdown-value">…</span>
			</div>
			<nav class="hero__nav" aria-label="Разделы">
				<a href="#when">Когда</a>
				<a href="#where">Где</a>
				<a href="#program">Программа</a>
				<a href="#dress">Дресс-код</a>
				<a href="#rsvp">Ответ</a>
			</nav>
		</header>

		<main id="main">
			<section class="section section--narrow" id="when">
				<h2 class="section__title">Когда</h2>
				<div class="card card--center">
					<p class="card__lead">{wedding.dateLabel}</p>
					<p class="card__muted">{wedding.timeLabel} · {wedding.timezone}</p>
				</div>
			</section>

			<section class="section" id="where">
				<h2 class="section__title">Где</h2>
				<div class="grid-two">
					<div class="card">
						<h3 class="card__subtitle">{venue.ceremonyTitle}</h3>
						<p class="card__lead">{venue.ceremonyPlace}</p>
						<p class="card__muted">{venue.ceremonyAddress}</p>
						<a class="button" href={venue.mapsUrl} target="_blank" rel="noopener noreferrer">Открыть карту</a>
					</div>
					<div class="card card--muted">
						<p>
							Если нужны трансфер или ночёвка — напишите нам при ответе на приглашение, мы пришлём
							варианты.
						</p>
					</div>
				</div>
			</section>

			<section class="section section--alt" id="program">
				<div class="section__inner">
					<h2 class="section__title">Программа</h2>
					<ol class="timeline">
						{
							program.map((item) => (
								<li class="timeline__item">
									<span class="timeline__time">{item.time}</span>
									<div class="timeline__body">
										<span class="timeline__title">{item.title}</span>
										{item.detail && <span class="timeline__detail">{item.detail}</span>}
									</div>
								</li>
							))
						}
					</ol>
				</div>
			</section>

			<section class="section section--narrow" id="dress">
				<h2 class="section__title">Дресс-код</h2>
				<div class="card">
					<p class="card__text">{dressCode}</p>
				</div>
			</section>

			<section class="section section--wide-rsvp" id="rsvp">
				<h2 class="section__title">Ответ на приглашение</h2>
				<div class="card card--accent">
					<p class="card__text">
						Пожалуйста, сообщите, сможете ли вы быть с нами, <strong>{rsvp.deadline}</strong> — по почте
						или в telegram.
					</p>
					<div class="rsvp-contacts">
						{
							rsvp.contacts.map((c) => (
								<div class="rsvp-contact">
									<p class="rsvp-contact__label">{c.label}</p>
									<div class="rsvp-contact__actions">
										<a class="button button--light" href={`mailto:${c.email}?subject=RSVP свадьба`}>
											{c.email}
										</a>
										<a class="button button--ghost" href={dialHref(c.phone)}>
											{c.phone}
										</a>
									</div>
								</div>
							))
						}
					</div>
				</div>
			</section>
		</main>

		<footer class="footer">
			<p>С нетерпением ждём встречи · {couple.names}</p>
			<a href="#top" class="footer__top">Наверх</a>
		</footer>

		<script define:vars={{ weddingTs }}>
			const el = document.getElementById("countdown-value");
			const root = document.getElementById("countdown");
			if (!el || !root) {
				// skip
			} else {
				const target = typeof weddingTs === "number" ? weddingTs : Number(root.dataset.ts);
				const fmt = (n) => String(Math.max(0, n)).padStart(2, "0");

				function tick() {
					const now = Date.now();
					let diff = target - now;
					if (diff <= 0) {
						el.textContent = "Сегодня этот особенный день!";
						return;
					}
					const s = Math.floor(diff / 1000) % 60;
					const m = Math.floor(diff / (1000 * 60)) % 60;
					const h = Math.floor(diff / (1000 * 60 * 60)) % 24;
					const d = Math.floor(diff / (1000 * 60 * 60 * 24));
					el.textContent = `${d} д. ${fmt(h)}:${fmt(m)}:${fmt(s)}`;
				}

				tick();
				setInterval(tick, 1000);
			}
		</script>

		<style>
			.hero {
				text-align: center;
				padding: clamp(3rem, 8vw, 5.5rem) 1.5rem 3rem;
				max-width: 40rem;
				margin: 0 auto;
			}

			.hero__eyebrow {
				font-family: var(--font-body);
				font-size: 0.75rem;
				letter-spacing: 0.35em;
				text-transform: uppercase;
				color: var(--accent-deep);
				margin: 0 0 1rem;
			}

			.hero__title {
				font-family: var(--font-display);
				font-weight: 500;
				font-size: clamp(2.75rem, 9vw, 4.25rem);
				line-height: 1.05;
				margin: 0 0 1rem;
				color: var(--ink);
			}

			.hero__tagline {
				font-family: var(--font-display);
				font-style: italic;
				font-size: clamp(1.25rem, 3.5vw, 1.5rem);
				color: var(--ink-soft);
				margin: 0 0 1.5rem;
				line-height: 1.4;
			}

			.hero__date {
				margin: 0 0 2rem;
				font-weight: 500;
				font-size: 1rem;
				color: var(--ink);
			}

			.hero__countdown {
				display: inline-flex;
				flex-direction: column;
				gap: 0.35rem;
				padding: 1rem 1.5rem;
				background: var(--bg-elevated);
				border: 1px solid var(--line);
				border-radius: var(--radius);
				box-shadow: var(--shadow);
				margin-bottom: 2.25rem;
			}

			.hero__countdown-label {
				font-size: 0.7rem;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: var(--ink-soft);
			}

			.hero__countdown-value {
				font-family: var(--font-display);
				font-size: 1.5rem;
				font-weight: 600;
				color: var(--accent-deep);
			}

			.hero__nav {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.75rem 1.25rem;
				font-size: 0.9rem;
			}

			.hero__nav a {
				color: var(--ink-soft);
				text-decoration: none;
				border-bottom: 1px solid transparent;
			}

			.hero__nav a:hover {
				color: var(--accent-deep);
				border-bottom-color: var(--accent);
			}

			.section {
				padding: clamp(2.5rem, 6vw, 4rem) 1.5rem;
			}

			.section--narrow {
				max-width: 36rem;
				margin: 0 auto;
			}

			.section--wide-rsvp {
				max-width: 52rem;
				margin: 0 auto;
			}

			.section--alt {
				background: var(--bg-elevated);
				border-top: 1px solid var(--line);
				border-bottom: 1px solid var(--line);
			}

			.section__inner {
				max-width: 40rem;
				margin: 0 auto;
			}

			.section__title {
				font-family: var(--font-display);
				font-weight: 500;
				font-size: clamp(1.75rem, 4vw, 2.25rem);
				text-align: center;
				margin: 0 0 2rem;
				color: var(--ink);
			}

			.grid-two {
				display: grid;
				gap: 1.25rem;
				max-width: 52rem;
				margin: 0 auto;
			}

			@media (min-width: 48rem) {
				.grid-two {
					grid-template-columns: 1fr 1fr;
					align-items: stretch;
				}
			}

			.card {
				background: var(--bg-elevated);
				border: 1px solid var(--line);
				border-radius: var(--radius);
				padding: 1.75rem 1.5rem;
				box-shadow: var(--shadow);
			}

			.card--center {
				text-align: center;
			}

			.card--muted {
				background: rgba(255, 255, 255, 0.55);
				box-shadow: none;
				display: flex;
				align-items: center;
			}

			.card--muted p {
				margin: 0;
				color: var(--ink-soft);
				font-size: 0.98rem;
			}

			.card--accent {
				border-color: rgba(157, 107, 92, 0.35);
				background: linear-gradient(145deg, #fffefb, #faf3ee);
			}

			.card__subtitle {
				font-family: var(--font-display);
				font-size: 1.25rem;
				font-weight: 600;
				margin: 0 0 0.5rem;
				color: var(--accent-deep);
			}

			.card__lead {
				font-family: var(--font-display);
				font-size: 1.5rem;
				margin: 0 0 0.35rem;
				line-height: 1.3;
			}

			.card__muted {
				margin: 0 0 1.25rem;
				color: var(--ink-soft);
				font-size: 0.95rem;
			}

			.card__text {
				margin: 0 0 1.25rem;
			}

			.card__text:last-child {
				margin-bottom: 0;
			}

			.card__actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin: 0;
			}

			.rsvp-contacts {
				display: grid;
				gap: 1.25rem;
				margin: 0;
			}

			@media (min-width: 36rem) {
				.rsvp-contacts {
					grid-template-columns: 1fr 1fr;
					gap: 1.5rem;
				}
			}

			.rsvp-contact {
				margin: 0;
				padding: 1.15rem 1.2rem;
				background: rgba(255, 255, 255, 0.65);
				border: 1px solid var(--line);
				border-radius: 0.85rem;
			}

			.rsvp-contact__label {
				font-family: var(--font-display);
				font-size: 1.2rem;
				font-weight: 600;
				color: var(--accent-deep);
				margin: 0 0 0.85rem;
			}

			.rsvp-contact__actions {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				gap: 0.65rem;
			}

			.rsvp-contact__actions .button {
				width: 100%;
				text-align: center;
				word-break: break-word;
			}

			@media (min-width: 36rem) {
				.rsvp-contact__actions .button {
					width: auto;
					min-width: 0;
					text-align: left;
				}
			}

			.button {
				display: inline-block;
				padding: 0.65rem 1.25rem;
				border-radius: 999px;
				font-weight: 500;
				font-size: 0.95rem;
				background: var(--accent-deep);
				color: #fff;
				text-decoration: none;
				border: 1px solid var(--accent-deep);
				transition:
					background 0.15s ease,
					color 0.15s ease,
					border-color 0.15s ease;
			}

			.button:hover {
				background: var(--accent);
				border-color: var(--accent);
				color: #fff;
			}

			.button--light {
				background: #fff;
				color: var(--accent-deep);
				border-color: var(--line);
			}

			.button--light:hover {
				background: var(--bg);
				color: var(--ink);
			}

			.button--ghost {
				background: transparent;
				color: var(--accent-deep);
				border-color: var(--accent);
			}

			.button--ghost:hover {
				background: rgba(157, 107, 92, 0.1);
			}

			.timeline {
				list-style: none;
				margin: 0;
				padding: 0;
				border-left: 1px solid var(--line);
				margin-left: 0.5rem;
			}

			.timeline__item {
				position: relative;
				padding: 0 0 1.75rem 1.75rem;
			}

			.timeline__item:last-child {
				padding-bottom: 0;
			}

			.timeline__item::before {
				content: "";
				position: absolute;
				left: -0.35rem;
				top: 0.35rem;
				width: 0.65rem;
				height: 0.65rem;
				border-radius: 50%;
				background: var(--bg-elevated);
				border: 2px solid var(--accent);
			}

			.timeline__time {
				display: block;
				font-variant-numeric: tabular-nums;
				font-weight: 600;
				font-size: 0.9rem;
				color: var(--accent-deep);
				margin-bottom: 0.25rem;
			}

			.timeline__body {
				display: flex;
				flex-direction: column;
				gap: 0.15rem;
			}

			.timeline__title {
				font-family: var(--font-display);
				font-size: 1.35rem;
				font-weight: 500;
			}

			.timeline__detail {
				font-size: 0.95rem;
				color: var(--ink-soft);
			}

			.footer {
				text-align: center;
				padding: 2.5rem 1.5rem 3rem;
				color: var(--ink-soft);
				font-size: 0.95rem;
			}

			.footer p {
				margin: 0 0 1rem;
				font-family: var(--font-display);
				font-style: italic;
				font-size: 1.1rem;
				color: var(--ink);
			}

			.footer__top {
				font-size: 0.85rem;
				color: var(--ink-soft);
			}
		</style>
	</body>
</html>
