---
import "../styles/global.css";

/** Путь к файлу в public/ (с или без ведущего /) */
const withBase = (path: string) => {
	const base = import.meta.env.BASE_URL;
	const file = path.replace(/^\//, "");
	return `${base.endsWith("/") ? base : `${base}/`}${file}`;
};
const assetUrl = (path: string | null) => (path ? withBase(path) : null);

/** Замените на свои данные */
const couple = {
	names: "Анна и Тимур",
	heroPhrase: "Мы женимся!",
	/** Фото в полароиде, например "photo.jpg" */
	photo: "/photo.png" as string | null,
};

/** Декор сверху, например "ball.png" в public/ */
const decorTop: string | null = "ball.png";

/** SVG-иллюстрации из public/ — замените при необходимости */
const icons = {
	route: "baloon.svg",
	dressCode: "dress.svg",
} as const;

const wedding = {
	iso: "2026-09-12T15:00:00",
	dateLabel: "12 сентября 2026",
	timeLabel: "15:00",
	timezone: "Москва",
};

const venue = {
	place: "Отель «Эдж Селигерская»",
	address: "г. Москва, Коровинское шоссе, 10",
	mapsUrl:
		"https://yandex.ru/maps/org/edzh_seligerskaya/1867560286/?ll=37.535646%2C55.870839&z=16",
};

/** SVG из public/ — поменяйте image при необходимости */
const program = [
	{ time: "15:00", title: "Сбор гостей", detail: "", image: "place.svg" },
	{ time: "16:00", title: "Церемония", detail: "веранда зала", image: "wed.svg" },
	{ time: "17:00", title: "Банкет", detail: "банкетный зал", image: "banquet.svg" },
	{ time: "20:00", title: "Торт и танцы", detail: "", image: "glass.svg" },
] as const;

const dressCode = "Для нас главное — ваше присутствие. Приходите так, чтобы Вам было комфортно.";

const details = [
	"В отеле «Эдж Селигерская» возможна бронь номера со скидкой для гостей. Напишите нам, чтобы узнать детали.",
];

const rsvp = {
	deadline: "до 21 июня 2026",
	contacts: [
		{
			label: "Анна",
			email: "dudar.anya@mail.ru",
			phone: "+7 909 649-68-16",
			vk: "https://vk.com/anechhhhkaa",
			telegram: "https://t.me/anyanya_du",
		},
		{
			label: "Тимур",
			email: "t.r.yakubov@gmail.com",
			phone: "+7 995 506-54-37",
			vk: "https://vk.com/notfoundium",
			telegram: "https://t.me/notfoundium",
		},
	],
} as const;

const dialHref = (phone: string) => `tel:${phone.replace(/[\s().-]/g, "")}`;

const weddingDate = new Date(wedding.iso);
const weddingDay = weddingDate.getDate();
const calendarYear = weddingDate.getFullYear();
const calendarMonth = weddingDate.getMonth();
const monthNameWavy = weddingDate.toLocaleDateString("ru-RU", { month: "long" });
const weekDays = ["ПН", "ВТ", "СР", "ЧТ", "ПТ", "СБ", "ВС"];
const daysInMonth = new Date(calendarYear, calendarMonth + 1, 0).getDate();
const startWeekday = (new Date(calendarYear, calendarMonth, 1).getDay() + 6) % 7;
const calendarCells: (number | null)[] = [];
for (let i = 0; i < startWeekday; i++) calendarCells.push(null);
for (let d = 1; d <= daysInMonth; d++) calendarCells.push(d);

const weddingTs = weddingDate.getTime();
const photoSrc = assetUrl(couple.photo);
const decorTopSrc = assetUrl(decorTop);
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={`Свадебное приглашение — ${couple.names}, ${wedding.dateLabel}`} />
		<title>{couple.names} — свадьба</title>
		<link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Jost:wght@300;400;500&family=Marck+Script&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<a class="sr-only" href="#main">Перейти к содержимому</a>

		<div class="invite">
			<header class="hero" id="top">
				<figure class="decor-slot decor-slot--top">
					{
						decorTopSrc ? (
							<img src={decorTopSrc} alt="" width="107" height="107" />
						) : (
							<div class="decor-slot__placeholder">
								<span class="decor-slot__hint">decor.top → decor-top.png</span>
							</div>
						)
					}
				</figure>
				<p class="hero__phrase">{couple.heroPhrase}</p>

				<figure class="polaroid">
					{
						photoSrc ? (
							<img src={photoSrc} alt={couple.names} width="420" height="315" />
						) : (
							<div class="polaroid__placeholder">
								<span class="polaroid__hint">ваше фото</span>
							</div>
						)
					}
				</figure>

				<h1 class="hero__names">{couple.names}</h1>
			</header>

			<main id="main">
				<section class="block block--calendar" id="when" aria-labelledby="cal-title">
					<h2 class="block__title block__title--sr" id="cal-title">Дата</h2>
					<p class="calendar__month">
						<span class="calendar__month-wavy">{monthNameWavy}</span>
					</p>
					<div class="calendar__weekdays">
						{weekDays.map((d) => <span>{d}</span>)}
					</div>
					<div class="calendar__grid">
						{
							calendarCells.map((day) =>
								day === null ? (
									<span class="calendar__cell calendar__cell--empty" />
								) : (
									<span
										class:list={[
											"calendar__cell",
											day === weddingDay && "calendar__cell--wedding",
										]}
									>
										{day === weddingDay ? (
											<span class="calendar__heart-wrap">
												<span class="calendar__day">{day}</span>
												<svg class="calendar__heart" viewBox="0 0 32 32" aria-hidden="true">
													<path
														d="M16 28s-10-6.5-10-14a5.5 5.5 0 0 1 10-3 5.5 5.5 0 0 1 10 3c0 7.5-10 14-10 14z"
														fill="none"
														stroke="currentColor"
														stroke-width="1.5"
													/>
												</svg>
											</span>
										) : (
											day
										)}
									</span>
								),
							)
						}
					</div>
				</section>

				<section class="block" id="where" aria-labelledby="loc-title">
					<h2 class="block__title" id="loc-title">Локация</h2>
					<p class="block__text block__text--center">
						Ждём вас в <strong>{venue.place}</strong>
						<br />
						<span class="block__muted">{venue.address}</span>
					</p>
					<p class="block__text block__text--center">
						Начало в {wedding.timeLabel} ({wedding.timezone})
					</p>
					<div class="block__cta">
						<a class="btn btn--with-icon" href={venue.mapsUrl} target="_blank" rel="noopener noreferrer">
							<img class="btn__icon" src={assetUrl(icons.route) ?? ""} alt="" width="18" height="18" />
							Маршрут
						</a>
					</div>
				</section>

				<section class="block" id="program" aria-labelledby="timing-title">
					<h2 class="block__title" id="timing-title">Тайминг</h2>
					<ol class="timing">
						{
							program.map((item) => (
								<li class="timing__row">
									<span class="timing__icon" aria-hidden="true">
										<img src={assetUrl(item.image) ?? ""} alt="" width="40" height="40" />
									</span>
									<div class="timing__content">
										<span class="timing__time">{item.time}</span>
										<span class="timing__title">{item.title}</span>
										{item.detail && <span class="timing__detail">{item.detail}</span>}
									</div>
								</li>
							))
						}
					</ol>
				</section>

				<section class="block" id="dress" aria-labelledby="dress-title">
					<h2 class="block__title" id="dress-title">Дресс-код</h2>
					<p class="block__text block__text--center">{dressCode}</p>
					<img
						class="dress-code__img"
						src={assetUrl(icons.dressCode) ?? ""}
						alt=""
						width="80"
						height="80"
					/>
				</section>

				<section class="block block--details" id="rsvp" aria-labelledby="details-title">
					<h2 class="block__title" id="details-title">Детали</h2>
					{
						details.map((paragraph) => (
							<>
								<p class="block__star" aria-hidden="true">✦</p>
								<p class="block__text block__text--center">{paragraph}</p>
							</>
						))
					}
					<p class="block__star" aria-hidden="true">✦</p>
					<p class="block__text block__text--center">
						Пожалуйста, подтвердите присутствие <strong>{rsvp.deadline}</strong> — напишите нам:
					</p>

					<div class="rsvp-grid">
						{
							rsvp.contacts.map((c) => (
								<div class="rsvp-card">
									<p class="rsvp-card__name">{c.label}</p>
									<div class="rsvp-card__links">
										<a
											class="btn btn--outline btn--email"
											href={`mailto:${c.email}?subject=RSVP свадьба`}
										>
											<span class="btn__email-text">{c.email}</span>
										</a>
										<a class="btn btn--outline" href={dialHref(c.phone)}>
											{c.phone}
										</a>
										<a class="btn btn--outline" href={c.vk} target="_blank" rel="noopener noreferrer">
											VK
										</a>
										<a
											class="btn btn--outline"
											href={c.telegram}
											target="_blank"
											rel="noopener noreferrer"
										>
											Telegram
										</a>
									</div>
								</div>
							))
						}
					</div>
				</section>

				<section class="block block--countdown" aria-labelledby="countdown-title">
					<h2 class="block__title block__title--countdown" id="countdown-title">
						До свадьбы осталось
					</h2>
					<div class="countdown" id="countdown" data-ts={weddingTs}>
						<div class="countdown__unit">
							<span class="countdown__num" id="cd-days">0</span>
							<span class="countdown__label">дней</span>
						</div>
						<div class="countdown__unit">
							<span class="countdown__num" id="cd-hours">00</span>
							<span class="countdown__label">часов</span>
						</div>
						<div class="countdown__unit">
							<span class="countdown__num" id="cd-mins">00</span>
							<span class="countdown__label">минут</span>
						</div>
						<div class="countdown__unit">
							<span class="countdown__num" id="cd-secs">00</span>
							<span class="countdown__label">секунд</span>
						</div>
					</div>
				</section>
			</main>

			<footer class="closing">
				<a href="#top" class="closing__up">Наверх</a>
			</footer>
		</div>

		<script define:vars={{ weddingTs }}>
			const fmt = (n) => String(Math.max(0, n)).padStart(2, "0");
			const daysEl = document.getElementById("cd-days");
			const hoursEl = document.getElementById("cd-hours");
			const minsEl = document.getElementById("cd-mins");
			const secsEl = document.getElementById("cd-secs");
			const root = document.getElementById("countdown");
			if (!daysEl || !hoursEl || !minsEl || !secsEl || !root) {
				// skip
			} else {
				const target =
					typeof weddingTs === "number" ? weddingTs : Number(root.dataset.ts);

				function tick() {
					let diff = target - Date.now();
					if (diff <= 0) {
						daysEl.textContent = "0";
						hoursEl.textContent = "00";
						minsEl.textContent = "00";
						secsEl.textContent = "00";
						return;
					}
					const s = Math.floor(diff / 1000) % 60;
					const m = Math.floor(diff / (1000 * 60)) % 60;
					const h = Math.floor(diff / (1000 * 60 * 60)) % 24;
					const d = Math.floor(diff / (1000 * 60 * 60 * 24));
					daysEl.textContent = String(d);
					hoursEl.textContent = fmt(h);
					minsEl.textContent = fmt(m);
					secsEl.textContent = fmt(s);
				}

				tick();
				setInterval(tick, 1000);
			}
		</script>

		<style>
			.hero {
				text-align: center;
				padding: 0.35rem 0 1.5rem;
			}

			.decor-slot {
				margin: 0;
				max-width: none;
			}

			.decor-slot img {
				width: 100%;
				height: auto;
				object-fit: contain;
				display: block;
			}

			.decor-slot--top {
				margin-inline: -0.85rem;
				margin-bottom: 0.35rem;
			}

			.decor-slot--top img {
				width: 66.67%;
				max-width: 10.5rem;
				margin-inline: auto;
			}

			.decor-slot__placeholder {
				min-height: 5rem;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 1rem;
				background: linear-gradient(160deg, #ebe6dc, #ddd6c8);
				border: 1px dashed var(--line);
				border-radius: 4px;
			}

			.decor-slot__hint {
				font-family: var(--font-body);
				font-size: 0.7rem;
				color: var(--ink-soft);
				text-align: center;
				line-height: 1.4;
			}

			.hero__phrase {
				font-family: var(--font-script);
				font-size: clamp(1.75rem, 6vw, 2.25rem);
				color: var(--burgundy);
				margin: 0 0 1.25rem;
				line-height: 1.2;
			}

			.polaroid {
				margin: 0 auto 1.25rem;
				padding: 0.65rem 0.65rem 2.5rem;
				background: #fff;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
				max-width: 21rem;
				transform: rotate(-2deg);
			}

			.polaroid img {
				width: 100%;
				aspect-ratio: 4 / 3;
				object-fit: cover;
			}

			.polaroid__placeholder {
				aspect-ratio: 4 / 3;
				background: linear-gradient(160deg, #e8e4dc, #d4cfc4);
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.polaroid__hint {
				font-family: var(--font-script);
				font-size: 1.1rem;
				color: var(--ink-soft);
				opacity: 0.7;
			}

			.hero__names {
				font-family: var(--font-script);
				font-size: clamp(1.85rem, 6.5vw, 2.5rem);
				font-weight: 400;
				color: var(--burgundy);
				margin: 0;
				line-height: 1.25;
			}

			.block {
				padding: 2rem 0;
				border-top: 1px solid var(--line);
			}

			.block__title {
				font-family: var(--font-serif);
				font-size: 1.05rem;
				font-weight: 500;
				letter-spacing: 0.35em;
				text-transform: uppercase;
				text-align: center;
				color: var(--ink);
				margin: 0 0 1.25rem;
			}

			.block__title--sr {
				position: absolute;
				width: 1px;
				height: 1px;
				overflow: hidden;
				clip: rect(0, 0, 0, 0);
			}

			.block__title--countdown {
				font-size: 0.75rem;
				letter-spacing: 0.12em;
				line-height: 1.4;
				max-width: 12rem;
				margin-left: auto;
				margin-right: auto;
			}

			.block__text {
				margin: 0 0 0.85rem;
				font-weight: 300;
			}

			.block__text--center {
				text-align: center;
			}

			.block__muted {
				font-size: 0.88rem;
				color: var(--ink-soft);
			}

			.block__star {
				text-align: center;
				color: var(--burgundy);
				font-size: 0.65rem;
				margin: 0.5rem 0;
				letter-spacing: 0.2em;
			}

			.block__cta {
				text-align: center;
				margin-top: 1.25rem;
			}

			.btn {
				display: inline-block;
				padding: 0.7rem 2.25rem;
				border-radius: 999px;
				font-family: var(--font-body);
				font-size: 0.7rem;
				font-weight: 500;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				text-decoration: none;
				background: var(--burgundy);
				color: #fff;
				border: none;
				transition: background 0.15s ease;
			}

			.btn:hover {
				background: var(--burgundy-deep);
				color: #fff;
			}

			.btn--with-icon {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
			}

			.btn--with-icon .btn__icon {
				width: 1.15rem;
				height: 1.15rem;
				object-fit: contain;
				flex-shrink: 0;
				filter: brightness(0) invert(1);
			}

			.dress-code__img {
				display: block;
				width: 4.5rem;
				height: 4.5rem;
				margin: 1.25rem auto 0;
				object-fit: contain;
			}

			.btn--outline {
				background: transparent;
				color: var(--burgundy);
				border: 1px solid var(--burgundy);
				padding: 0.55rem 1rem;
				font-size: 0.65rem;
				letter-spacing: 0.08em;
				width: 100%;
				text-align: center;
				word-break: break-word;
			}

			.btn--outline:hover {
				background: rgba(123, 36, 56, 0.08);
			}

			.btn--email {
				letter-spacing: 0;
				text-transform: none;
				font-weight: 400;
				line-height: 1.35;
				padding: 0.55rem 0.65rem;
				font-size: clamp(0.5rem, 2.6vw, 0.68rem);
			}

			.btn__email-text {
				display: block;
				overflow-wrap: anywhere;
				word-break: break-word;
				hyphens: auto;
			}

			.calendar__month {
				font-family: var(--font-serif);
				font-size: 1.1rem;
				letter-spacing: 0.25em;
				text-align: center;
				margin: 0 0 1rem;
				text-transform: uppercase;
			}

			.calendar__month-wavy {
				text-decoration-line: underline;
				text-decoration-style: wavy;
				text-decoration-color: var(--burgundy);
				text-underline-offset: 0.25em;
				text-decoration-thickness: 1px;
			}

			.calendar__weekdays,
			.calendar__grid {
				display: grid;
				grid-template-columns: repeat(7, 1fr);
				gap: 0.25rem;
				text-align: center;
				font-size: 0.8rem;
				font-weight: 400;
			}

			.calendar__weekdays {
				margin-bottom: 0.5rem;
				color: var(--ink-soft);
				font-size: 0.65rem;
				letter-spacing: 0.05em;
			}

			.calendar__cell {
				aspect-ratio: 1;
				display: flex;
				align-items: center;
				justify-content: center;
				position: relative;
			}

			.calendar__cell--empty {
				visibility: hidden;
			}

			.calendar__cell--wedding {
				color: var(--burgundy);
				font-weight: 500;
			}

			.calendar__heart-wrap {
				position: relative;
				display: flex;
				align-items: center;
				justify-content: center;
				width: 2rem;
				height: 2rem;
			}

			.calendar__heart {
				position: absolute;
				inset: -4px;
				width: calc(100% + 8px);
				height: calc(100% + 8px);
				color: var(--burgundy);
			}

			.calendar__day {
				position: relative;
				z-index: 1;
				font-size: 0.85rem;
			}

			.timing {
				list-style: none;
				margin: 0;
				padding: 0;
				position: relative;
				--timing-line: 3rem;
			}

			.timing::before {
				content: "";
				position: absolute;
				left: var(--timing-line);
				top: 0.5rem;
				bottom: 0.5rem;
				width: 2px;
				background: var(--burgundy);
				border-radius: 1px;
				transform: translateX(-50%);
			}

			.timing__row {
				display: grid;
				grid-template-columns: var(--timing-line) 1fr;
				gap: 0;
				padding: 0 0 1.5rem 0;
				position: relative;
			}

			.timing__row:last-child {
				padding-bottom: 0;
			}

			.timing__row::after {
				content: "";
				position: absolute;
				left: var(--timing-line);
				top: 1.35rem;
				width: 7px;
				height: 7px;
				border-radius: 50%;
				background: var(--burgundy);
				transform: translateX(-50%);
				z-index: 1;
			}

			.timing__icon {
				display: flex;
				align-items: flex-start;
				justify-content: center;
				padding-top: 0.1rem;
				padding-right: 0.65rem;
			}

			.timing__icon img {
				width: 2.25rem;
				height: 2.25rem;
				object-fit: contain;
			}

			.timing__content {
				padding-left: 1rem;
			}

			.timing__time {
				display: block;
				font-size: 0.8rem;
				font-weight: 500;
				letter-spacing: 0.05em;
				margin-bottom: 0.15rem;
			}

			.timing__title {
				font-family: var(--font-script);
				font-size: 1.35rem;
				color: var(--burgundy);
				line-height: 1.2;
				display: block;
			}

			.timing__detail {
				display: block;
				font-size: 0.8rem;
				color: var(--ink-soft);
				font-weight: 300;
				margin-top: 0.1rem;
			}

			.block--details .rsvp-grid {
				margin-top: 1.5rem;
			}

			.rsvp-grid {
				display: grid;
				gap: 1rem;
			}

			@media (min-width: 22rem) {
				.rsvp-grid {
					grid-template-columns: 1fr 1fr;
				}
			}

			.rsvp-card {
				padding: 1rem;
				border: 1px solid var(--line);
				border-radius: 0.5rem;
				background: rgba(255, 255, 255, 0.5);
			}

			.rsvp-card__links {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}

			.rsvp-card__name {
				font-family: var(--font-script);
				font-size: 1.35rem;
				color: var(--burgundy);
				margin: 0 0 0.25rem;
				text-align: center;
			}

			.countdown {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 0.5rem;
				text-align: center;
			}

			.countdown__num {
				display: block;
				font-family: var(--font-serif);
				font-size: clamp(1.75rem, 7vw, 2.25rem);
				font-weight: 500;
				color: var(--burgundy);
				line-height: 1.1;
				font-variant-numeric: tabular-nums;
			}

			.countdown__label {
				display: block;
				font-size: 0.6rem;
				text-transform: lowercase;
				color: var(--ink-soft);
				margin-top: 0.25rem;
				letter-spacing: 0.02em;
			}

			.closing {
				text-align: center;
				padding: 2rem 0 1rem;
				border-top: 1px solid var(--line);
			}

			.closing__up {
				font-size: 0.75rem;
				color: var(--ink-soft);
				text-decoration: none;
				letter-spacing: 0.1em;
				text-transform: uppercase;
			}

			.closing__up:hover {
				color: var(--burgundy);
			}
		</style>
	</body>
</html>
